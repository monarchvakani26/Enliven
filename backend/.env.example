# ================================================
# SafeSphere AI — Environment Configuration
# ================================================

# --- Google Gemini API Key (Layer 2 — LLM) ---
# Free tier at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Cloud Natural Language API (Layer 2b — optional) ---
# Enables Google's trained content safety model (moderateText API)
# Free tier: 5,000 units/month
# Get key: https://console.cloud.google.com → APIs → Natural Language API
# GOOGLE_NL_API_KEY=your_google_cloud_api_key_here

# --- LLM Provider ---
LLM_PROVIDER=gemini

# --- MongoDB (optional — uses in-memory if not set) ---
# Get free Atlas cluster at: https://cloud.mongodb.com
# MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=safesphere

# --- App Settings ---
FRONTEND_URL=http://localhost:5173
